# --- Mode local ---
# Quand "true": l'app tourne 100% sur ton ordi, les données vont dans localStorage,
# pas besoin de Supabase. Mets "false" plus tard quand tu auras configuré Supabase.
NEXT_PUBLIC_LOCAL_MODE=true

# --- Supabase (à remplir plus tard quand tu sors du mode local) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- IA (optionnel — non utilisé en mode local) ---
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Email (optionnel) ---
RESEND_API_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
